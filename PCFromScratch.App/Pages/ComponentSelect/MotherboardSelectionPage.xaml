<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PCFromScratch.App.ViewModels"
             xmlns:dbModels="clr-namespace:PCFromScratch.DBModels;assembly=PCFromScratch.DBModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="PCFromScratch.App.Pages.MotherboardSelectionPage"
             x:DataType="viewModels:MotherboardSelectionViewModel"
             Title="Вибір материнської плати">
    <StackLayout>
        <SearchBar Placeholder="Пошук..." Text="{Binding SearchTerm}" />
        <CollectionView ItemsSource="{Binding Parts}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dbModels:MotherboardRenamedForOmnissiah">
                    <toolkit:Expander>
                        <toolkit:Expander.Header>
                            <Grid Padding="10" ColumnDefinitions="*,Auto">
                                <Label Text="{Binding  Name, FallbackValue='Another One Bites The Dust'}" VerticalOptions="Center" />
                                <Label Text="{Binding Id, FallbackValue='Шо, опять?'}"/>
                                <Button Grid.Column="1" Text="Обрати" Command="{Binding Path=BindingContext.SelectCommand, Source={ RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}" />
                            </Grid>
                        </toolkit:Expander.Header>
                        <StackLayout Padding="10">
                            <Label Text="{Binding Socket, StringFormat='Сокет: {0}'}" />
                            <Label Text="{Binding FormFactor, StringFormat='Форм-фактор: {0}'}" />
                            <Label Text="{Binding Chipset, StringFormat='Чипсет: {0}'}" />
                            <Label Text="{Binding RamGeneration, StringFormat='Тип ОЗП: {0}'}" />
                            <Label Text="{Binding RamSlots, StringFormat='Слоти ОЗП: {0}'}" />
                            <Label Text="{Binding RamFrequency, StringFormat='Макс. частота ОЗП: {0} MHz'}" />
                        </StackLayout>
                    </toolkit:Expander>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </StackLayout>
</ContentPage>