<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PCFromScratch.App.ViewModels"
             xmlns:dbModels="clr-namespace:PCFromScratch.DBModels;assembly=PCFromScratch.DBModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="PCFromScratch.App.Pages.CpuSelectionPage"
             x:DataType="viewModels:CpuSelectionViewModel"
             Title="Вибір процесора">
    <StackLayout>
        <SearchBar Placeholder="Пошук..." Text="{Binding SearchTerm}" />
        <CollectionView ItemsSource="{Binding Parts}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dbModels:Cpu">
                    <toolkit:Expander>
                        <toolkit:Expander.Header>
                            <Grid Padding="10" ColumnDefinitions="*,Auto">
                                <Label Text="{Binding Name}" VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="Обрати" Command="{Binding Path=BindingContext.SelectCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding}" />
                            </Grid>
                        </toolkit:Expander.Header>
                        <StackLayout Padding="10">
                            <Label Text="{Binding Socket, StringFormat='Сокет: {0}'}" />
                            <Label Text="{Binding Tdp, StringFormat='TDP: {0} W'}" />
                        </StackLayout>
                    </toolkit:Expander>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </StackLayout>
</ContentPage>