<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PCFromScratch.App.ViewModels"
             xmlns:dtoModels="using:PCFromScratch.DTOModels"
             x:Class="PCFromScratch.App.Pages.GpuSelectionPage"
             x:DataType="viewModels:GpuSelectionViewModel">
    <Shell.TitleView>
        <Grid HorizontalOptions="Fill">
            <Label Text="Вибір відеокарти"
                   FontFamily="DniproCityBold"
                   FontSize="36"
                   TextColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource SecondaryDarkText}}"
                   HorizontalOptions="Center" />
        </Grid>
    </Shell.TitleView>
    <Grid RowDefinitions="Auto, *">
        <SearchBar Grid.Row="0" Placeholder="Пошук..." Text="{Binding SearchTerm}" />
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Parts}"
                        RemainingItemsThreshold="5"
                        RemainingItemsThresholdReachedCommand="{Binding LoadMorePartsCommand}"
                        ItemsUpdatingScrollMode="KeepScrollOffset">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"></LinearItemsLayout>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dtoModels:GpuDtoModel">
                    <Border Margin="10,5" Padding="10" StrokeShape="RoundRectangle 10" StrokeThickness="2">
                        <Grid ColumnDefinitions="100, *" RowDefinitions="Auto, Auto" ColumnSpacing="15">
                            
                            <Image Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                                   Source="{Binding Image}" 
                                   Aspect="AspectFit" 
                                   HeightRequest="100" 
                                   WidthRequest="100" 
                                   VerticalOptions="Center" />

                            <StackLayout Grid.Row="0" Grid.Column="1" Spacing="5">
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" />
                                <Label Text="{Binding Tdp, StringFormat='TDP: {0} W'}" />
                                <Label Text="{Binding Length, StringFormat='Довжина: {0} мм'}" />
                                <Label>
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Ціна: від " />
                                            <Span Text="{Binding MinPrice}" />
                                            <Span Text=" до " />
                                            <Span Text="{Binding MaxPrice}" />
                                            <Span Text=" грн" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </StackLayout>

                            <Button Grid.Row="1" Grid.Column="1" 
                                    Text="Обрати" 
                                    Margin="0,10,0,0"
                                    HorizontalOptions="End"
                                    Command="{Binding Path=BindingContext.SelectCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" 
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>