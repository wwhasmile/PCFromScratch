<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PCFromScratch.App.Pages.ComponentSelectionPage"
             Title="Вибір компонента">
    <StackLayout>
        <SearchBar x:Name="SearchBar" Placeholder="Пошук..." TextChanged="SearchBar_TextChanged" />
        <CollectionView x:Name="PartCollectionView">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10" ColumnDefinitions="*,Auto">
                        <Label Text="{Binding Name}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="Обрати" Clicked="SelectButton_Clicked" CommandParameter="{Binding}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </StackLayout>
</ContentPage>
