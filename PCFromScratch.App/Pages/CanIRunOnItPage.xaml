<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:PCFromScratch.App.ViewModels"
             x:Class="PCFromScratch.App.Pages.CanIRunOnItPage"
             x:DataType="viewmodels:CanIRunOnItViewModel"
             Title="Чи запуститься?">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">
            
            <!-- PC Specs -->
            <Label Text="Ваш ПК" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
            <Border StrokeShape="RoundRectangle 10" StrokeThickness="2" Padding="10">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding CpuName, StringFormat='Процесор: {0}'}" />
                    <Label Text="{Binding GpuName, StringFormat='Відеокарта: {0}'}" />
                    <Label Text="{Binding RamName, StringFormat='ОЗП: {0}'}" />
                    <Label Text="{Binding PsuName, StringFormat='БЖ: {0}'}" />
                    <Label Text="{Binding StorageNames, StringFormat='Сховище: {0}'}" />
                </VerticalStackLayout>
            </Border>

            <!-- Requirements Constructor -->
            <Label Text="Системні вимоги" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
            <VerticalStackLayout Spacing="10">
                
                <Border Padding="10" StrokeShape="RoundRectangle 10" StrokeThickness="2">
                    <Label Text="{Binding SelectedCpuBenchmarkName, FallbackValue='Оберіть процесор'}" VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectCpuBenchmarkCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <Border Padding="10" StrokeShape="RoundRectangle 10" StrokeThickness="2">
                    <Label Text="{Binding SelectedGpuBenchmarkName, FallbackValue='Оберіть відеокарту'}" VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SelectGpuBenchmarkCommand}" />
                    </Border.GestureRecognizers>
                </Border>

                <Border Padding="10" StrokeShape="RoundRectangle 10" StrokeThickness="2">
                    <Entry Placeholder="Оперативна пам'ять (MB)" Text="{Binding RamInMegabytes}" Keyboard="Numeric" />
                </Border>

                <Border Padding="10" StrokeShape="RoundRectangle 10" StrokeThickness="2">
                    <VerticalStackLayout Spacing="5">
                        <Entry Placeholder="Місце на диску (GB)" Text="{Binding SpaceOnDiskInGigabytes}" Keyboard="Numeric" />
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Потребує SSD" VerticalOptions="Center" FontAttributes="Bold"/>
                            <Switch IsToggled="{Binding Requirements.SsdRequired}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>
                
            </VerticalStackLayout>

            <!-- Check Button & Result -->
            <Button Text="Check Compatibility" Command="{Binding CheckRequirementsCommand}" />
            <Label Text="{Binding ResultMessage}" HorizontalOptions="Center" HorizontalTextAlignment="Center" FontSize="16" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>